# GitHub PAT, fine-grained, read-only on the four watched repos.
# Generate at github.com/settings/tokens?type=beta
GH_TOKEN=

# LLM provider router. Options: groq (default) | anthropic | claude_code
RADAR_LLM=groq

# Free tier signup at console.groq.com — Llama 3.3 70B Versatile, 30 RPM.
GROQ_API_KEY=

# Only needed when RADAR_LLM=anthropic
ANTHROPIC_API_KEY=

# ntfy.sh topics. Pick unguessable strings (these are public).
# Subscribe to both in the ntfy mobile app.
NTFY_TOPIC=lily-inference-firsts-CHANGE-ME
NTFY_TOPIC_SPECULATIVE=lily-inference-firsts-spec-CHANGE-ME

# SQLite path
RADAR_DB=data/radar.db
