# GitHub PAT, fine-grained, read-only on the four watched repos.
# Generate at github.com/settings/tokens?type=beta
GH_TOKEN=

# LLM provider router. Options: groq (default) | anthropic | claude_code
RADAR_LLM=groq

# Free tier signup at console.groq.com — Llama 3.3 70B Versatile, 30 RPM.
GROQ_API_KEY=

# Only needed when RADAR_LLM=anthropic
ANTHROPIC_API_KEY=

# Optional: cap on output tokens for Anthropic calls. Default 16384 (was 4096
# pre-2026-05-14; the brief script generator was getting truncated at 4096
# when input contained ~300 PRs). Bump for very long briefings, lower if
# you want stricter cost control on per-call max spend.
ANTHROPIC_MAX_TOKENS=16384

# ntfy.sh topics. Pick unguessable strings (these are public).
# Subscribe to both in the ntfy mobile app.
NTFY_TOPIC=lily-inference-firsts-CHANGE-ME
NTFY_TOPIC_SPECULATIVE=lily-inference-firsts-spec-CHANGE-ME

# Per-repo PR alert feeds (radar.pr_alerts). Six topics, two per repo:
#   *-bw  = open + unassigned PRs in the past 3 days about Blackwell + CUTLASS
#           / CuTeDSL (LLM-verified, false-positives suppressed).
#   *-all = every open + unassigned PR in the past 3 days, no LLM filter.
# Cap of 3 ntfy pushes per feed per run. Pick easy-to-type, distinctive topics.
NTFY_TOPIC_VLLM_BW=lily-vllm-bw-CHANGE-ME
NTFY_TOPIC_VLLM_ALL=lily-vllm-all-CHANGE-ME
NTFY_TOPIC_SGL_BW=lily-sgl-bw-CHANGE-ME
NTFY_TOPIC_SGL_ALL=lily-sgl-all-CHANGE-ME
NTFY_TOPIC_TRT_BW=lily-trt-bw-CHANGE-ME
NTFY_TOPIC_TRT_ALL=lily-trt-all-CHANGE-ME

# SQLite path
RADAR_DB=data/radar.db

# Optional: where the daily brief writes intermediate files (script.json,
# slides/*.png, audio/*.wav, brief.mp4). Default: ./out
RADAR_OUT=out

# Piper TTS voice model path. The GH workflow downloads en_US-lessac-medium.
# Override for local runs.
PIPER_MODEL=/usr/share/piper-voices/en_US-lessac-medium.onnx

# Where radar.export writes the static JSON the Next.js site reads. Default:
# site/data
RADAR_SITE_DATA=site/data

# Where novel category proposals get queued for human-PR review. Default:
# data/uncategorized.json
RADAR_UNCATEGORIZED=data/uncategorized.json

# --- YouTube upload (optional; brief.py runs locally without these) ---
# Set up via console.cloud.google.com → OAuth client (Desktop app), then mint
# a refresh token with the one-time helper in docs/youtube_oauth.md (TBD).
# If the OAuth project stays in "Testing" mode, refresh tokens expire in 7 days;
# submit for verification (free) to make them durable.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
